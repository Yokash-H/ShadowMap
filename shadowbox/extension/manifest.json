{
  "manifest_version": 3,
  "name": "ShadowBox — File Analyzer",
  "version": "1.0.0",
  "description": "Analyze downloaded files for malicious behavior before execution. Powered by ShadowBox Consequence Visualization Engine.",
  "permissions": [
    "downloads",
    "activeTab",
    "storage",
    "notifications"
  ],
  "host_permissions": [
    "http://127.0.0.1:8000/*",
    "http://localhost:8000/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
