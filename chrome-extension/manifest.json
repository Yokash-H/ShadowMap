{
  "manifest_version": 3,
  "name": "ShadowMap AI",
  "version": "1.1.0",
  "description": "Real-time cybersecurity overlay. Press F4 for instant risk analysis.",
  "permissions": [
    "activeTab",
    "tabs",
    "storage",
    "notifications",
    "scripting"
  ],
  "host_permissions": [
    "http://localhost:5000/*",
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "overlay.css"
      ]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "inject.js"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ],
  "action": {
    "default_popup": "popup/popup.html"
  },
  "commands": {
    "trigger-analysis": {
      "suggested_key": {
        "default": "Alt+Shift+F"
      },
      "description": "Trigger ShadowMap Analysis"
    }
  }
}
